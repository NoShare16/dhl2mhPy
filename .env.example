# Copy to .env and fill in real values. .env is gitignored.
# Environment: dev = DHL UAT, prod = DHL production
APP_ENV=dev

# Plenty
PLENTY__USERNAME=
PLENTY__PASSWORD=

# Shopware
SHOPWARE__CLIENT_ID=
SHOPWARE__CLIENT_SECRET=

# DHL DeliverIT (Basic Auth, password gets SHA1-hashed by the client)
DHL__UAT_USERNAME=HDE
DHL__UAT_PASSWORD=
DHL__PROD_USERNAME=HDE
DHL__PROD_PASSWORD=
DHL__LABEL_WAIT_SECONDS=180

# SMTP for skipped-orders report
SMTP__HOST=smtp.mailbox.org
SMTP__PORT=587
SMTP__USERNAME=
SMTP__PASSWORD=
SMTP__FROM_EMAIL=
SMTP__FROM_NAME="DHL Label Service"

# Where the skipped-orders report goes
REPORT_RECIPIENT_EMAIL=
